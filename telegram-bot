import asyncio
import aiohttp
import re
from bs4 import BeautifulSoup

BOT_TOKEN = "PASTE_YOUR_TOKEN"
CHAT_ID = "7179654594"

SEARCHES = [
    "prop firm coupon",
    "prop firm discount code",
    "free challenge prop firm",
    "funded account giveaway"
]

def extract_codes(text):
    patterns = [
        r"\b[A-Z]{4,10}[0-9]{2,4}\b",
        r"\b[A-Z0-9]{6,12}\b",
        r"\bFREE[A-Z0-9]{2,8}\b"
    ]

    results = set()
    text = text.upper()

    for p in patterns:
        matches = re.findall(p, text)
        for m in matches:
            if any(c.isdigit() for c in m):
                results.add(m)

    return list(results)

async def send(session, msg):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    await session.post(url, data={"chat_id": CHAT_ID, "text": msg})

async def scan(session, query):
    url = f"https://nitter.net/search?f=tweets&q={query.replace(' ', '+')}"
    async with session.get(url) as res:
        html = await res.text()

    soup = BeautifulSoup(html, "html.parser")
    tweets = soup.find_all("div", class_="tweet-content")

    for t in tweets[:10]:
        text = t.get_text()
        codes = extract_codes(text)

        if codes:
            msg = f"CODE FOUND\n\n{text[:120]}\n\nCodes: {', '.join(codes)}"
            await send(session, msg)

async def main():
    async with aiohttp.ClientSession() as session:
        while True:
            tasks = [scan(session, q) for q in SEARCHES]
            await asyncio.gather(*tasks)
            await asyncio.sleep(15)

asyncio.run(main())
